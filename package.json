{
  "name": "@dsb-norge/vue-keycloak-js",
  "version": "3.0.8",
  "author": "Norwegian Directorate for Civil Protection",
  "description": "A Keycloak plugin for Vue >= 3.x",
  "type": "module",
  "main": "dist/dsb-vue-keycloak.cjs",
  "module": "dist/dsb-vue-keycloak.es.js",
  "browser": "dist/dsb-vue-keycloak.umd.js",
  "typings": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/dsb-vue-keycloak.es.js",
      "require": "./dist/dsb-vue-keycloak.cjs"
    }
  },
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git@github.com:dsb-norge/vue-keycloak-js.git"
  },
  "bugs": {
    "url": "https://github.com/dsb-norge/vue-keycloak-js/issues"
  },
  "homepage": "https://github.com/dsb-norge/vue-keycloak-js",
  "dependencies": {
    "keycloak-js": "26.2.4"
  },
  "keywords": [
    "vue",
    "keycloak"
  ],
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@vitejs/plugin-vue": "6.0.7",
    "@vue/language-core": "3.3.5",
    "eslint": "10.5.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.0",
    "vite": "8.1.0",
    "vite-plugin-dts": "5.0.3",
    "vue": "3.5.38"
  },
  "peerDependencies": {
    "vue": ">=3.0.0"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "files": [
    "dist"
  ]
}
